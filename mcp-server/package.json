{
  "name": "playwright-mcp-server",
  "version": "2.0.0",
  "description": "Dual-transport MCP server — stdio for Desktop, HTTP for Web claude.ai via ngrok",
  "type": "module",
  "scripts": {
    "start:stdio":      "node src/index.js --transport=stdio",
    "start:http":       "node src/index.js --transport=http",
    "start:http:ngrok": "node scripts/start-with-ngrok.js",
    "dev:stdio":        "node --watch src/index.js --transport=stdio",
    "dev:http":         "node --watch src/index.js --transport=http"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^3.25.0"
  }
}